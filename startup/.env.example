# =============================================================================
# startup/.env — Single source of truth for ALL secrets
# DO NOT commit this file. Copy .env.example and fill in your values.
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ── MySQL ─────────────────────────────────────────────────────────────────────
# These exact names are required by MySQL's official Docker image
MYSQL_ROOT_PASSWORD=<INPUT_HERE>
MYSQL_DATABASE=<INPUT_HERE>
MYSQL_HOST=localhost
MYSQL_PORT=3306

# ── Redis ─────────────────────────────────────────────────────────────────────
# REDIS_PASSWORD is used by redis.conf AND the redis-server command in docker-compose
REDIS_PASSWORD=<INPUT_HERE>
REDIS_HOST=localhost
REDIS_PORT=6379


# Required for Prisma and Render Deployment
# DATABASE_URL="mysql://root:123456789@localhost:3307/social_network"
# REDIS_URL="redis://localhost:6379"

JWT_SECRET_KEY=hehetuiladevvietday
