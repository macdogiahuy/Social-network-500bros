generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Model database

model Users {
  id            String        @id @map("id") @db.VarChar(36)
  email         String       @unique @map("email") @db.VarChar(255)
  cover         String?       @db.VarChar(255)
  avatar        String?       @map("avatar") @db.VarChar(255)
  username      String        @unique @map("username") @db.VarChar(100)
  firstName     String        @map("first_name") @db.VarChar(100)
  lastName      String        @map("last_name") @db.VarChar(100)
  password      String        @map("password") @db.VarChar(100)
  salt          String        @map("salt") @db.VarChar(50)
  role          users_role    @default(user) @map("role")
  bio           String?       @map("bio") @db.VarChar(255)
  websiteUrl    String?       @map("website_url") @db.VarChar(255)
  followerCount Int?          @default(0) @map("follower_count") @db.UnsignedInt
  postCount     Int?          @default(0) @map("post_count") @db.UnsignedInt
  status        users_status? @default(active) @map("status")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamp(0)

  // Relations
  createdRooms       ChatRooms[]            @relation("RoomCreator")
  roomParticipations ChatRoomParticipants[]
  chatMessages       ChatMessages[]
  posts              Posts[]
  comments           Comments[]
  commentLikes       CommentLikes[]
  postLikes          PostLikes[]
  postSaves          PostSaves[]
  stories            Stories[]
  storyLikes         StoryLikes[]
  storyViews         StoryViews[]
  messageReactions   ChatMessageReactions[]
  // --- Follow Relations Example ---
  // If John follows Jane:
  // Jane will appear in John's `following` list.
  // John will appear in Jane's `followers` list.
  followers          Follow[]               @relation("UserFollowedBy") // People following THIS user
  following          Follow[]               @relation("UserFollows") // People THIS user is following
  notifications      Notifications[]        @relation("NotificationsReceived")
  notificationsSent  Notifications[]        @relation("NotificationsSent")

  @@index([role], map: "role")
  @@index([status], map: "status")
  @@map("users")
}

model Follow {
  createdAt DateTime @map("created_at") @db.Timestamp(0)

  // --- Foreign Relations ---
  // Example scenario: "John" clicks "Follow" on "Jane"'s profile.
  // -> followerId  = John's ID (The person who initiated the follow)
  // -> followingId = Jane's ID (The person who is being followed)

  followerId String @map("follower_id") @db.VarChar(36)
  follower   Users  @relation("UserFollows", fields: [followerId], references: [id], onDelete: Cascade) // Links back to John

  followingId String @map("following_id") @db.VarChar(36)
  following   Users  @relation("UserFollowedBy", fields: [followingId], references: [id], onDelete: Cascade) // Links back to Jane

  @@id([followingId, followerId])
  @@index([followerId], map: "follower_id")
  @@map("follows")
}

// --- Chat Rooms ---
model ChatRooms {
  // Primary Key
  id String @id @map("id") @db.VarChar(36)

  // Data Fields
  name   String?            @map("name") @db.VarChar(255)
  image  String?            @map("image") @db.VarChar(512)
  type   chat_rooms_type?   @default(direct) @map("type")
  status chat_rooms_status? @default(pending) @map("status")

  // Timestamps
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamp(0)
  deletedAt DateTime? @map("deleted_at") @db.Timestamp(0)

  // Foreign Keys & Relations
  creatorId String @map("creator_id") @db.VarChar(36)
  creator   Users  @relation("RoomCreator", fields: [creatorId], references: [id])

  messages     ChatMessages[]
  participants ChatRoomParticipants[] // 1 Room has Many Participants

  // Indexes & Config
  @@index([creatorId], map: "creator_id")
  @@map("chat_rooms")
}

// Junction Table: Many to many relation Users <--> ChatRooms
model ChatRoomParticipants {
  users   Users  @relation(fields: [usersId], references: [id], onDelete: Cascade)
  usersId String @db.VarChar(36)

  chatRooms   ChatRooms @relation(fields: [chatRoomsId], references: [id], onDelete: Cascade)
  chatRoomsId String    @db.VarChar(36)

  role     chat_room_role? @default(MEMBER) @map("role") // admin vs member
  joinedAt DateTime        @default(now()) @map("joined_at") @db.Timestamp(0)

  @@id([chatRoomsId, usersId])
  @@index([usersId], map: "users_id")
  @@map("chat_room_participants")
}

model ChatMessages {
  // Primary Key
  id        String   @id @map("id") @db.VarChar(36)
  // Data Fields
  content   String?  @map("content") @db.Text
  fileUrl   String?  @map("file_url") @db.VarChar(512)
  fileName  String?  @map("file_name") @db.VarChar(255)
  fileSize  Int?     @map("file_size")
  fileType  String?  @map("file_type") @db.VarChar(100)
  // Timestamps
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  // Foreign Keys & Relations
  roomId   String    @map("room_id") @db.VarChar(36)
  room     ChatRooms @relation(fields: [roomId], references: [id], onDelete: Cascade)
  senderId String?   @map("sender_id") @db.VarChar(36)
  sender   Users?    @relation(fields: [senderId], references: [id], onDelete: SetNull)

  reactions ChatMessageReactions[]

  // Indexes & Config
  @@index([roomId], map: "room_id")
  @@index([senderId], map: "sender_id")
  @@index([roomId, createdAt(sort: Desc)], map: "room_created_at")
  @@map("chat_messages")
}

model ChatMessageReactions {
  id        String   @id @map("id") @db.VarChar(36)
  emoji     String   @map("emoji") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  messageId String       @map("message_id") @db.VarChar(36)
  message   ChatMessages @relation(fields: [messageId], references: [id], onDelete: Cascade)

  userId String @map("user_id") @db.VarChar(36)
  user   Users  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId], map: "message_id")
  @@index([userId], map: "reaction_user_id")
  @@map("chat_message_reactions")
}

// --- Post model ---
model Posts {
  // Primary Key
  id           String      @id @map("id") @db.VarChar(36)
  // Data Fields
  content      String      @map("content") @db.Text
  image        String?     @map("image") @db.VarChar(255)
  isFeatured   Boolean     @default(false) @map("is_featured")
  commentCount Int         @default(0) @map("comment_count") @db.UnsignedInt
  likedCount   Int         @default(0) @map("liked_count") @db.UnsignedInt
  type         posts_type? @default(text) @map("type")
  // Timestamps
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamp(0)

  // Foreign Keys & Relations
  authorId String @map("author_id") @db.VarChar(36)
  author   Users  @relation(fields: [authorId], references: [id], onDelete: Cascade)

  topicId  String      @map("topic_id") @db.VarChar(36)
  topic    Topics      @relation(fields: [topicId], references: [id], onDelete: Cascade)
  comments Comments[]
  likes    PostLikes[]
  saves    PostSaves[]
  tags     PostTags[]

  // Indexes & Config
  @@index([authorId], map: "author_id")
  @@index([topicId], map: "topic_id")
  @@index([isFeatured], map: "is_featured")
  @@index([createdAt(sort: Desc)], map: "created_at_desc")
  @@index([authorId, createdAt(sort: Desc)], map: "author_created_at")
  @@index([topicId, createdAt(sort: Desc)], map: "topic_created_at")
  @@map("posts")
}

model Topics {
  // Primary Key
  id        String   @id @map("id") @db.VarChar(36)
  // Data Fields
  name      String   @unique @map("name") @db.VarChar(100)
  postCount Int?     @default(0) @map("post_count") @db.UnsignedInt
  // Timestamps
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(0)
  color     String   @map("color") @db.VarChar(10)
  // Relations
  posts     Posts[]

  // Indexes & Config
  @@map("topics")
}

model Comments {
  // Primary Key
  id         String          @id @map("id") @db.VarChar(36)
  // Data Fields
  content    String          @map("content") @db.Text
  likedCount Int             @default(0) @map("liked_count")
  replyCount Int             @default(0) @map("reply_count")
  status     comments_status @default(pending) @map("status")
  // Timestamps
  createdAt  DateTime        @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt  DateTime        @updatedAt @map("updated_at") @db.Timestamp(0)

  // Foreign Keys & Relations
  userId String @map("user_id") @db.VarChar(36)
  user   Users  @relation(fields: [userId], references: [id], onDelete: Cascade)

  postId String @map("post_id") @db.VarChar(36)
  post   Posts  @relation(fields: [postId], references: [id], onDelete: Cascade)

  // Self-relation
  // One parent comment can have multiple replies
  parentId String?    @map("parent_id") @db.VarChar(36)
  parent   Comments?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: NoAction)
  replies  Comments[] @relation("CommentReplies")

  commentLikes CommentLikes[]

  @@index([userId], map: "user_id")
  @@index([parentId], map: "parent_id")
  @@index([status], map: "status")
  @@index([postId, createdAt(sort: Desc)], map: "post_created_at")
  @@map("comments")
}

model CommentLikes {
  createdAt DateTime @map("created_at") @db.Timestamp(0)

  // Foreign relation
  commentId String   @map("comment_id") @db.VarChar(36)
  comment   Comments @relation(fields: [commentId], references: [id], onDelete: Cascade)

  userId String @map("user_id") @db.VarChar(36)
  user   Users  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([commentId, userId])
  @@index([createdAt(sort: Desc)], map: "created_at_desc")
  @@map("comment_likes")
}

model Notifications {
  // Primary Key
  id        String                @id @map("id") @db.VarChar(36)
  // Data Fields
  content   String?               @map("content") @db.Text
  action    notifications_action? @map("action")
  isSent    Boolean               @default(false) @map("is_sent")
  isRead    Boolean               @default(false) @map("is_read")
  // Timestamps
  createdAt DateTime              @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime              @updatedAt @map("updated_at") @db.Timestamp(0)

  // Foreign relation
  receiverId String  @map("receiver_id") @db.VarChar(36)
  receiver   Users   @relation("NotificationsReceived", fields: [receiverId], references: [id], onDelete: Cascade)
  actorId    String? @map("actor_id") @db.VarChar(36)
  actor      Users?  @relation("NotificationsSent", fields: [actorId], references: [id], onDelete: SetNull)
  
  @@index([receiverId, isRead], map: "receiver_read")
  @@index([receiverId, createdAt(sort: Desc)], map: "receiver_created_at")
  @@index([actorId], map: "actor_id")
    @@map("notifications")
}

model PostLikes {
  createdAt DateTime @map("created_at") @db.Timestamp(0)

  // Foreign relation
  postId String @map("post_id") @db.VarChar(36)
  post   Posts  @relation(fields: [postId], references: [id], onDelete: Cascade)

  userId String @map("user_id") @db.VarChar(36)
  user   Users  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@index([userId], map: "user_id")
  @@index([createdAt(sort: Desc)], map: "created_at_desc")
  @@map("post_likes")
}

model PostSaves {
  createdAt DateTime @map("created_at") @db.Timestamp(0)

  // Foreign relation
  postId String @map("post_id") @db.VarChar(36)
  post   Posts  @relation(fields: [postId], references: [id], onDelete: Cascade)

  userId String @map("user_id") @db.VarChar(36)
  user   Users  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@index([userId], map: "user_id")
  @@map("post_saves")
}

model PostTags {
  createdAt DateTime @map("created_at") @db.Timestamp(0)

  // Foreign relation
  postId String @map("post_id") @db.VarChar(36)
  post   Posts  @relation(fields: [postId], references: [id], onDelete: Cascade)

  tagId String @map("tag_id") @db.VarChar(36)
  tag   Tags   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId], map: "tag_id")
  @@map("post_tags")
}

model Stories {
  // Primary Key
  id        String         @id @map("id") @db.VarChar(36)
  // Data Fields
  content   String?        @map("content") @db.Text
  likeCount Int            @default(0) @map("like_count") @db.UnsignedInt
  viewCount Int            @default(0) @map("view_count") @db.UnsignedInt
  media     Json?
  status    stories_status @default(active) @map("status")
  // Timestamps
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime       @updatedAt @map("updated_at") @db.Timestamp(0)
  expiresAt DateTime       @map("expires_at") @db.Timestamp(0)

  // Foreign relation
  userId String @map("user_id") @db.VarChar(36)
  user   Users  @relation(fields: [userId], references: [id], onDelete: Cascade)

  likes StoryLikes[]
  views StoryViews[]

  @@index([status], map: "status")
  @@index([expiresAt(sort: Asc)], map: "expires_at_asc")
  @@index([userId, createdAt(sort: Desc)], map: "user_created_at")
  @@map("stories")
}

model StoryLikes {
  createdAt DateTime @map("created_at") @db.Timestamp(0)

  storyId String  @map("story_id") @db.VarChar(36)
  story   Stories @relation(fields: [storyId], references: [id], onDelete: Cascade)

  userId String @map("user_id") @db.VarChar(36)
  user   Users  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([storyId, userId])
  @@index([userId], map: "user_id")
  @@map("story_likes")
}

model StoryViews {
  createdAt DateTime @map("created_at") @db.Timestamp(0)

  storyId String  @map("story_id") @db.VarChar(36)
  story   Stories @relation(fields: [storyId], references: [id], onDelete: Cascade)

  userId String @map("user_id") @db.VarChar(36)
  user   Users  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([storyId, userId])
  @@index([userId], map: "user_id")
  @@map("story_views")
}

model Tags {
  id        String   @id @map("id") @db.VarChar(36)
  name      String   @unique @map("name") @db.VarChar(50)
  postCount Int?     @default(0) @map("post_count") @db.UnsignedInt
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  posts PostTags[]

  @@map("tags")
}

enum notifications_action {
  liked
  followed
  replied
}

enum chat_rooms_type {
  direct
  group
}

enum chat_rooms_status {
  pending
  active
  deleted
}

enum chat_room_role {
  ADMIN
  MEMBER
}

enum stories_status {
  active
  inactive
}

enum comments_status {
  pending
  approved
  rejected
  deleted
  spam
}

enum posts_type {
  text
  media
}

enum users_role {
  user
  admin
}

enum users_status {
  active
  pending
  inactive
  banned
  deleted
}
